{
  "jsonrpc": "2.0",
  "id": 2,
  "result": {
    "tools": [
      {
        "name": "config_backup",
        "description": "【变更类·非破坏】为指定配置文件创建带时间戳的备份副本（<path>.bak-<时间戳>），真实执行时受管备份目录同步留存快照并登记回滚账本（可一键恢复）。与其他变更工具共用护栏裁决与 pendingMutationId + confirm=true 二次确认门禁；默认 dry-run",
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "待备份配置文件的绝对路径，如 /etc/nginx/nginx.conf、/etc/my.cnf"
            },
            "confirm": {
              "type": "boolean",
              "description": "二次确认标志：首次调用返回风险裁决（REVIEW_PENDING），审阅后需同时携带 pendingMutationId 才会执行",
              "default": false
            },
            "pendingMutationId": {
              "type": "string",
              "description": "首次 REVIEW_PENDING 返回的待确认变更 id；confirm=true 时必须携带且与同一工具/参数匹配"
            }
          },
          "required": [
            "path"
          ],
          "additionalProperties": false
        },
        "annotations": {
          "title": "config_backup",
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        }
      },
      {
        "name": "db_sense",
        "description": "采集数据库运行状态（免凭据只读探测）：服务进程(ps)、监听端口(ss)与已建立连接数，支持 MySQL/PostgreSQL/Redis；可选 engine 指定引擎（默认 auto 全部探测），目标机未部署对应数据库时优雅降级",
        "inputSchema": {
          "type": "object",
          "properties": {
            "engine": {
              "type": "string",
              "description": "要探测的数据库引擎；auto 表示依次探测全部三种",
              "enum": [
                "auto",
                "mysql",
                "postgresql",
                "redis"
              ],
              "default": "auto"
            }
          },
          "additionalProperties": false
        },
        "annotations": {
          "title": "db_sense",
          "readOnlyHint": true,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        }
      },
      {
        "name": "disk_sense",
        "description": "采集磁盘信息：各文件系统使用率(df)与指定目录占用(du)；可选 path 指定探查目录(默认 /var/log)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "du 探查的绝对目录路径（非绝对路径将回退默认值）",
              "pattern": "^/",
              "default": "/var/log",
              "examples": [
                "/var/log",
                "/data",
                "/tmp",
                "/home"
              ]
            }
          },
          "additionalProperties": false
        },
        "annotations": {
          "title": "disk_sense",
          "readOnlyHint": true,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        }
      },
      {
        "name": "log_rotate",
        "description": "【变更类】轮转指定日志文件：先复制归档为 <path>.<时间戳>，再将原文件截断为 0 字节释放磁盘。仅允许 /var/log/ 下或以 .log 结尾的文件。内置安全闭环：护栏风险裁决、pendingMutationId + confirm=true 二次确认、执行前自动备份、回滚账本登记；默认 dry-run 不真实落盘",
        "inputSchema": {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "待轮转日志文件的绝对路径，须位于 /var/log/ 下或以 .log 结尾，如 /var/log/nginx/access.log"
            },
            "confirm": {
              "type": "boolean",
              "description": "二次确认标志：首次调用返回风险裁决（REVIEW_PENDING），审阅后需同时携带 pendingMutationId 才会执行",
              "default": false
            },
            "pendingMutationId": {
              "type": "string",
              "description": "首次 REVIEW_PENDING 返回的待确认变更 id；confirm=true 时必须携带且与同一工具/参数匹配"
            }
          },
          "required": [
            "path"
          ],
          "additionalProperties": false
        },
        "annotations": {
          "title": "log_rotate",
          "readOnlyHint": false,
          "destructiveHint": true,
          "idempotentHint": false,
          "openWorldHint": false
        }
      },
      {
        "name": "log_sense",
        "description": "采集日志信息：最近的错误级别 systemd 日志(journalctl -p err)；可选 unit 限定某个服务单元、lines 指定行数(默认 100)",
        "inputSchema": {
          "type": "object",
          "properties": {
            "unit": {
              "type": "string",
              "description": "systemd 服务单元名；留空则采集全系统错误日志",
              "examples": [
                "nginx",
                "sshd",
                "mysqld",
                "docker"
              ]
            },
            "lines": {
              "type": "integer",
              "description": "拉取的日志行数",
              "minimum": 1,
              "maximum": 1000,
              "default": 100
            }
          },
          "additionalProperties": false
        },
        "annotations": {
          "title": "log_sense",
          "readOnlyHint": true,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        }
      },
      {
        "name": "metrics_sense",
        "description": "采集监控系统指标（Prometheus 文本格式）：source=node-exporter 抓取主机监控(默认 127.0.0.1:9100/metrics)，source=actuator 抓取本服务自监控(默认 127.0.0.1:8080/actuator/prometheus)；可选 filter 按指标名前缀过滤、lines 限制返回行数；端点不可达时优雅降级",
        "inputSchema": {
          "type": "object",
          "properties": {
            "source": {
              "type": "string",
              "description": "指标来源：node-exporter=主机级监控（需目标机部署 node_exporter），actuator=本服务自监控端点",
              "enum": [
                "node-exporter",
                "actuator"
              ],
              "default": "node-exporter"
            },
            "port": {
              "type": "integer",
              "description": "监控端点端口；缺省 node-exporter=9100、actuator=8080",
              "minimum": 1,
              "maximum": 65535
            },
            "filter": {
              "type": "string",
              "description": "指标名前缀过滤，如 node_load、node_memory、jvm_memory；留空返回全部（受 lines 限制）"
            },
            "lines": {
              "type": "integer",
              "description": "最多返回的指标行数（注释行不计）",
              "minimum": 1,
              "maximum": 500,
              "default": 50
            }
          },
          "additionalProperties": false
        },
        "annotations": {
          "title": "metrics_sense",
          "readOnlyHint": true,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        }
      },
      {
        "name": "network_sense",
        "description": "采集网络信息：监听中的端口及进程(ss -tnlp)、各状态连接统计(ss -s)；可选 port 只聚焦某个端口（监听方 + 已建立连接）",
        "inputSchema": {
          "type": "object",
          "properties": {
            "port": {
              "type": "integer",
              "description": "只聚焦该端口：返回其监听进程与已建立连接；留空返回全量监听端口与统计",
              "minimum": 1,
              "maximum": 65535
            }
          },
          "additionalProperties": false
        },
        "annotations": {
          "title": "network_sense",
          "readOnlyHint": true,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        }
      },
      {
        "name": "process_sense",
        "description": "采集进程信息：按 CPU 占用排序的进程列表，含状态列以识别僵尸进程；可选 limit 只取前 N 个进程",
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "description": "只返回 CPU 占用前 N 个进程；留空或 0 返回全部",
              "minimum": 0,
              "maximum": 200,
              "default": 0
            }
          },
          "additionalProperties": false
        },
        "annotations": {
          "title": "process_sense",
          "readOnlyHint": true,
          "destructiveHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        }
      },
      {
        "name": "service_restart",
        "description": "【变更类】重启指定 systemd 服务单元（systemctl restart），真实执行成功后自动以 systemctl is-active 复核服务状态。内置安全闭环：护栏风险裁决（核心服务自动升级为高危）、pendingMutationId + confirm=true 二次确认、溯源审计；默认 dry-run 不真实落盘",
        "inputSchema": {
          "type": "object",
          "properties": {
            "unit": {
              "type": "string",
